@model List<ClinicQueueFrontend.Models.DoctorQueueModel>

<h2 class="mb-4">Doctor Queue</h2>

<div class="card shadow">
    <div class="card-body">

        <table class="table table-bordered">

            <thead class="table-dark">
                <tr>
                    <th>Token</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>
                        <td class="align-middle fw-bold">@item.tokenNumber</td>
                        <td class="align-middle">
                            @if(item.status == "waiting") { <span class="badge bg-secondary">Waiting</span> }
                            else if(item.status == "in_progress") { <span class="badge bg-primary">In Progress</span> }
                            else if(item.status == "done") { <span class="badge bg-success">Done</span> }
                            else if(item.status == "skipped") { <span class="badge bg-warning text-dark">Skipped</span> }
                            else { <span class="badge bg-light text-dark">@item.status</span> }
                        </td>
                        <td>
                            <a asp-action="AddPrescription" asp-route-appointmentId="@item.appointmentId" class="btn btn-success btn-sm me-1"><i class="bi bi-prescription2"></i> Prescription</a>
                            <a asp-action="AddReport" asp-route-appointmentId="@item.appointmentId" class="btn btn-warning btn-sm text-dark"><i class="bi bi-file-earmark-medical"></i> Report</a>
                        </td>
                    </tr>
                }

            </tbody>

        </table>

        @if (!Model.Any())
        {
            <p class="text-danger mt-3">No patients in queue</p>
        }

    </div>
</div>